# Local OperationsCenter environment — copy to .env.operations-center.local and fill in values.
# Source this file before running worker/smoke commands.
# This file is safe to commit. .env.operations-center.local is gitignored.
#
# Split model:
#   config/operations_center.local.yaml holds structure and behaviour (safe to version).
#   This file holds secrets and runtime knobs (never commit real values).

# ---------------------------------------------------------------------------
# Secrets (never commit real values)
# ---------------------------------------------------------------------------

# Plane API token (from Plane → Settings → API Tokens)
export PLANE_API_TOKEN='your-plane-api-token'

# GitHub token — option A: pull live from gh CLI (requires: gh auth login)
export GITHUB_TOKEN=$(awk '/oauth_token:/{print $2}' ~/.config/gh/hosts.yml)
# GitHub token — option B: classic PAT with repo scope
# export GITHUB_TOKEN='github_pat_...'
# GitHub token — option C: fine-grained PAT (per-repo scope)
# export GITHUB_TOKEN='github_pat_...'
# Per-repo token override (referenced by token_env in config yaml):
# export GITHUB_TOKEN_MYREPO='github_pat_...'

# ---------------------------------------------------------------------------
# Plane
# ---------------------------------------------------------------------------

export OPERATIONS_CENTER_PLANE_URL='http://localhost:8080'

# ---------------------------------------------------------------------------
# Execution controls
# ---------------------------------------------------------------------------
# Rolling budget windows protect against runaway execution costs.
# Skips are non-blocking: budget exhaustion is logged and treated as a valid
# outcome, not an error. Adjust these to match your API plan.

export OPERATIONS_CENTER_MAX_EXEC_PER_HOUR=10
export OPERATIONS_CENTER_MAX_EXEC_PER_DAY=50
export OPERATIONS_CENTER_MAX_RETRIES_PER_TASK=3

# Minimum remaining daily budget before proposal creation is suppressed.
export OPERATIONS_CENTER_MIN_REMAINING_EXEC_FOR_PROPOSALS=3

# ---------------------------------------------------------------------------
# Watcher poll intervals (seconds)
# ---------------------------------------------------------------------------
# Lower values make the system more responsive but increase API call volume.

export OPERATIONS_CENTER_WATCH_INTERVAL_GOAL_SECONDS=30
export OPERATIONS_CENTER_WATCH_INTERVAL_TEST_SECONDS=60
export OPERATIONS_CENTER_WATCH_INTERVAL_IMPROVE_SECONDS=60
export OPERATIONS_CENTER_WATCH_INTERVAL_PROPOSE_SECONDS=120
# Review watcher drives the PR review loop: self-review passes, human-phase revisions,
# and 👍-triggered merges. Also handles 1-day timeout auto-merge.
export OPERATIONS_CENTER_WATCH_INTERVAL_REVIEW_SECONDS=60

# ---------------------------------------------------------------------------
# PR automation safety
# ---------------------------------------------------------------------------
# Set to 1 to enable dry-run mode: PR creation/merge is skipped and the
# intended action is logged instead. Useful for validating the automation
# path without actually touching GitHub PRs.
# export OPERATIONS_CENTER_PR_DRY_RUN=0

# ---------------------------------------------------------------------------
# Plane startup
# ---------------------------------------------------------------------------

export OPERATIONS_CENTER_PLANE_START_COMMAND='./deployment/plane/manage.sh up'
# Set to 1 to open the Plane URL in a browser on dev-up
export OPERATIONS_CENTER_PLANE_OPEN_BROWSER='0'

# ---------------------------------------------------------------------------
# SwitchBoard integration (Phase 5)
# ---------------------------------------------------------------------------
# When set, all spec-author LLM calls are routed through SwitchBoard
# instead of the Claude CLI.  SwitchBoard must be running at this URL.
# (ADR 0007: spec authoring moved into the spec-author task-kind handler in
# board_worker; the legacy spec_director watcher was retired in Phase F.)
# export SWITCHBOARD_URL='http://localhost:20401'

# ---------------------------------------------------------------------------
# Executor sandbox + egress confinement (SBX)
# ---------------------------------------------------------------------------
# All fail-open (§0.1 degrade-never-halt): unavailable/unset => runs as before,
# never a halt. When ENABLED-but-degraded the harness now logs an observable
# `sandbox_degraded` / `netns_degraded` warning (the audit's "absent isolation
# must be visible" requirement) so the log sweep can alert on it.

# bwrap process containment for the executor subprocess (Phase 2).
export OC_BWRAP_SANDBOX=1
# Route the sandbox's HTTPS egress through the L7/SNI allowlist proxy
# (oc-egress-proxy.service). Honor-system on its own — see OC_EGRESS_NETNS.
export OC_EGRESS_PROXY=http://127.0.0.1:8889
# Pin SNI == CONNECT host at the proxy (blocks SNI-smuggling). No new dependency.
export OC_EGRESS_SNI_STRICT=1
# STRUCTURAL egress confinement (B1): run the executor in a rootless pasta netns
# with an in-netns iptables OUTPUT DROP, so a raw socket bypassing the proxy is
# kernel-blocked. Requires the `passt` package (provides `pasta`).
export OC_EGRESS_NETNS=1

# FAIL-CLOSED containment opt-in (B4, determinism surface 8). By default the
# sandbox + egress confinement are fail-open (§0.1 degrade-never-halt): if bwrap
# or pasta is missing, the backend runs un-contained. Set these to refuse to run
# a token-holding backend without containment — a degrade then fails the cycle
# (observably, via the heartbeat) instead of silently dropping isolation. Leave
# UNSET to preserve degrade-never-halt.
# export OC_SANDBOX_REQUIRED=1
# export OC_EGRESS_REQUIRED=1

# ---------------------------------------------------------------------------
# Defaults
# ---------------------------------------------------------------------------

# Default repo key (must match a key in config yaml repos section)
export OPERATIONS_CENTER_DEFAULT_REPO='MyRepo'
